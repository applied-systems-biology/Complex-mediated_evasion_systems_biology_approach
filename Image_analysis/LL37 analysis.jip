      "9bc9dd80-a07c-45a9-b8d8-9d4d1f0fe05c/series-annotation" : {
        "name" : "Annotate with series",
        "description" : "If enabled, attempt to extract the series number (starting with 1) from the last part of the image title. The algorithm will take a look at the end of the title and expects a string '#[series]'. If none could be found, 1 will be returned."
      },
      "a2479b31-f8a5-427d-9fc7-9440175e933f/jipipe:data-batch-generation/annotation-merge-strategy" : {
        "name" : "Merge same annotation values",
