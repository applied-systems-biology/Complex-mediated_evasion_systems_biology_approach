      "d7905d30-f5cf-4a31-9fa3-68d98ffa2110/series-to-import" : {
        "name" : "Series to import",
        "description" : "Some images can contain multiple sub-images (series) that do not necessarily have the same size and other properties. Use this list to control which series should be imported. Overridden by 'Open all series'. The first index is zero."
      },
      "cec3bfe2-58c0-4403-8e5b-0414e17e0683/fill-color" : {
        "name" : "Fill color",
        "description" : "Allows to change the fill color when rendered as RGB and within ImageJ. The color can be a common color name (e.g. 'red'), a hex color (e.g. '#ff00ff'), or an RGB color (e.g. '0,128,255')."
      },
      "b52233c1-d02c-460f-96b0-52878d614359/jipipe:algorithm:enabled" : {
