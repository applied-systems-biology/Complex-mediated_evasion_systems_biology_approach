      "0a4f76e8-b5f2-4eb8-a556-75c787f4fdb8/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "66afdeb7-e686-445c-be24-89d31e22005d/stack-size-annotation" : {
        "name" : "Annotate with stack size (Z)",
        "description" : "If enabled, an annotation with provided name is created. The annotation contains the image stack size (number of Z slices)."
      },
      "70624f6f-14d4-4d01-bbce-c40f1d6576e5/jipipe:algorithm:pass-through" : {
        "pinned" : true,
        "name" : "Pass through",
        "description" : "If enabled, the algorithm will pass the input data directly to the output data without any processing. This is different from enabling/disabling the algorithm as this will not disable dependent algorithms.\nPlease note that setting this parameter via adaptive parameters (if available) does not always yield the expected result. The reason behind this is that pass-through is not trivial for certain nodes. We recommend to use a split node if node execution should be made adaptive."
      },
      "1c68cddb-8605-49bc-967d-2220e5ce2f08/jipipe:node:name" : {
        "pinned" : true,
        "name" : "Name",
        "description" : "Custom algorithm name."
      },
      "2cd274e5-f46f-4243-9b17-e273c6dec258/jipipe:data-batch-generation/limit" : {
        "name" : "Limit",
        "description" : "Limits which iteration steps are generated. The first index is zero."
      },
      "86a4844a-685b-444b-a237-19b1c1e4a5f2/expression-c" : {
        "name" : "Generate channel slices",
        "description" : "Expression that is executed for each Z/C/T slice and generates an array of slice indices (or a single slice index) that determine which C indices are exported. All indices begin with zero. Indices outside the available range are automatically wrapped. Return an empty array to skip a slice."
      },
      "a1cde252-50b2-444c-8651-144c63ac0b77/color-mode" : {
        "name" : "Color mode",
        "description" : "Color mode - Visualizes channels according to the specified scheme.  Possible choices are:\nDefault - Display channels as closely as possible to how they are stored in the file.\nComposite - Open as a merged composite image. Channels are colorized according to metadata present in the dataset (if any), or in the following default order: 1=red, 2=green, 3=blue, 4=gray, 5=cyan, 6=magenta, 7=yellow.\nColorized - Open with each channel in a separate plane, colorized according to metadata present in the dataset (if any), or in the default order (see Composite above).\nGrayscale - Open with each channel in a separate plane, displayed in plain grayscale.\nCustom - Same as Colorized, except that you can explicitly choose how to colorize each channel.\nNote that ImageJ can only composite together 7 or fewer channels. With more than 7 channels, some of the modes above may not work."
      },
      "4360e43a-4ecb-47b2-93ab-156357b64b49/jipipe:adaptive-parameters/attach-parameter-annotations" : {
        "name" : "Attach parameter annotations",
        "description" : "If multiple parameters are allowed, attach the parameter values as annotations."
      },
      "1c68cddb-8605-49bc-967d-2220e5ce2f08/physical-dimension-t-annotation" : {
        "name" : "Annotate with physical dimension (Time)",
        "description" : "If enabled, the time unit for multi-frame images is annotated to the image."
      },
      "b52233c1-d02c-460f-96b0-52878d614359/jipipe:parameter-slot-algorithm/parameter-annotations-prefix" : {
