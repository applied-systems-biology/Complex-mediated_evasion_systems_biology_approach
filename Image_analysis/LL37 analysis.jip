      "fcc559ab-48ec-4075-8905-7eb0b869be4e/max-particle-circularity" : {
        "name" : "Max particle circularity",
        "description" : "The maximum circularity (circularity = 4pi(area/perimeter^2)). The value range is from 0-1. If an object is not within the circularity range, it is removed from the results."
