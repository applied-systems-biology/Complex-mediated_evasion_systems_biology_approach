      "4360e43a-4ecb-47b2-93ab-156357b64b49/jipipe:local-parallelization-num-threads" : {
        "pinned" : true,
        "name" : "Local parallelization",
        "description" : "If enabled, override the partition- and run-wide parallelization settings and apply parallelization only on this node."
      },
      "f9fb85fa-e1dc-4086-a90d-063221266d63/jipipe:data-batch-generation/data-annotation-merge-strategy" : {
        "name" : "Merge same data annotation values",
        "description" : "Determines which strategy is applied if different values for the same data annotation columns are encountered."
      },
      "4360e43a-4ecb-47b2-93ab-156357b64b49/last-modified-time-annotation" : {
        "name" : "Annotate with last modification time",
        "description" : "If enabled, the path is annotated with its last modification time. The format is ISO 8601: <code>YYYY-MM-DDThh:mm:ss[.s+]Z</code>"
      },
      "a1cde252-50b2-444c-8651-144c63ac0b77/jipipe:parameter-slot-algorithm/attach-parameter-annotations" : {
        "name" : "Attach parameter annotations",
        "description" : "If multiple parameters are allowed, attach the parameter values as annotations."
      },
      "70624f6f-14d4-4d01-bbce-c40f1d6576e5/row-normalization" : {
        "name" : "Row normalization",
        "description" : "Determines how missing column values are handled if the input tables have different numbers of rows. You can set it to zero/empty (depending on numeric or string type), to the row number (starting with zero), copy the last value, or cycle."
      },
      "1b927947-ed5d-4bcc-b77f-e6cca765a3a4/jipipe:local-parallelization-num-threads" : {
        "pinned" : true,
        "name" : "Local parallelization",
        "description" : "If enabled, override the partition- and run-wide parallelization settings and apply parallelization only on this node."
      },
      "9bc9dd80-a07c-45a9-b8d8-9d4d1f0fe05c/jipipe:parameter-slot-algorithm/parameter-annotations-use-internal-names" : {
        "name" : "Parameter annotations use internal names",
        "description" : "Generated parameter annotations use their internal unique names."
      },
      "68ff4290-d421-49ed-a411-ca585f79e7f3/jipipe:data-batch-generation/annotation-matching-method" : {
        "name" : "Annotation matching method",
        "description" : "Allows to customize when two annotation sets are considered as equal. By default, non-empty annotation values should match exactly. You can also use a custom expression, instead."
      },
      "0a4f76e8-b5f2-4eb8-a556-75c787f4fdb8/jipipe:parameter-slot-algorithm/attach-parameter-annotations" : {
        "name" : "Attach parameter annotations",
        "description" : "If multiple parameters are allowed, attach the parameter values as annotations."
      },
      "bfb3813d-39ce-4b90-b304-6b7bd8210baa/jipipe:parameter-slot-algorithm/has-parameter-slot" : {
        "name" : "Multiple parameters",
        "description" : "If enabled, there will be an additional slot that consumes parameter data sets. The algorithm then will be applied for each of this parameter sets."
      },
      "86aa0bb7-dc0d-4122-b7db-fcb360fb7cde/jipipe:node:bookmarked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Bookmark this node",
        "description" : "If enabled, the node is highlighted in the graph editor UI and added into the bookmark list."
      },
      "a558b5f8-8552-45ad-b7ec-a08074ac54ea/swap-dimensions" : {
        "name" : "Swap dimensions",
        "description" : "Allows reassignment of dimensional axes (e.g., channel, Z and time).  Bio-Formats is supposed to be smart about handling multidimensional image data, but in some cases gets things wrong. For example, when stitching together a dataset from multiple files using the Group files with similar names option, Bio-Formats may not know which dimensional axis the file numbering is supposed to represent. It will take a guess, but in case it guesses wrong, you can use Swap dimensions to reassign which dimensions are which."
      },
      "63e14dd7-fdba-43cd-ae7d-51bbcedb6ebb/enable-filter" : {
        "important" : true,
        "name" : "Enable filter",
        "description" : "Determines if the filter is enabled"
      },
      "0fd6892a-2543-4b74-9579-59751a7615bf/jipipe:adaptive-parameters/overridden-parameters" : {
        "important" : true,
        "name" : "Overridden parameters",
        "description" : "Here you can override the value of parameters based on annotations. The 'Value' settings should return a value for the parameter type or a JSON string that can be converted into a valid parameter value. The 'Parameter key' setting determines to which parameter this value is written to."
      },
      "121b944d-4539-45b8-a72c-3d809f0c7b00/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "37447462-4d78-4e14-96a1-d59b25bdfe8a/expression-z" : {
        "name" : "Generate Z slices",
        "description" : "Expression that is executed for each Z/C/T slice and generates an array of slice indices (or a single slice index) that determine which Z indices are exported. All indices begin with zero. Indices outside the available range are automatically wrapped. Return an empty array to skip a slice."
      },
      "37447462-4d78-4e14-96a1-d59b25bdfe8a/expression-t" : {
        "name" : "Generate frame slices",
        "description" : "Expression that is executed for each Z/C/T slice and generates an array of slice indices (or a single slice index) that determine which T indices are exported. All indices begin with zero. Indices outside the available range are automatically wrapped. Return an empty array to skip a slice."
      },
      "68ff4290-d421-49ed-a411-ca585f79e7f3/jipipe:local-parallelization-num-threads" : {
