        "name" : "Solver",
        "description" : "Allows to override the iteration step solver"
      },
      "4d2d4139-d605-4ec7-8315-2fa8be4ebe2a/jipipe:data-batch-generation/limit" : {
        "name" : "Limit",
        "description" : "Limits which iteration steps are generated. The first index is zero."
      },
      "d7905d30-f5cf-4a31-9fa3-68d98ffa2110/auto-scale" : {
        "name" : "Auto scale",
        "description" : "Stretches the channel histograms to each channel's global minimum and maximum value throughout the stack. Does not alter underlying values in the image.  If unselected, all channel histograms are scaled to the image's digitization bit depth. Note that this range may be narrower than the bit depth of the file. For example, a 16-bit file may contain intensities digitized to 16-bits (0-65,535), to 12-bits (0-4,095), to 10-bits (0-1,023), etc.  Note that you can use the Brightness & Contrast or Window/Level controls to adjust the contrast range regardless of whether this option is used. The histogram will provide min/max values in the stack."
      },
      "ba93e421-bee2-4ada-a874-4850de697fdc/sigma-y" : {
        "name" : "Sigma (Y)",
        "description" : "Standard deviation of the Gaussian (pixels) in Y direction. If zero or less, sigma in X direction is automatically used instead."
      },
      "b97a7ee5-a104-4591-8c27-ff6fe6a3627a/jipipe:parameter-slot-algorithm/attach-parameter-annotations" : {
        "name" : "Attach parameter annotations",
        "description" : "If multiple parameters are allowed, attach the parameter values as annotations."
      },
      "1bab2531-3751-436d-98e9-0d6a857767e1/jipipe:algorithm:runtime-partition" : {
        "pinned" : true,
        "name" : "Partition",
        "description" : "Allows to move the node into a different runtime partition, which determine how the workload is executed."
      },
