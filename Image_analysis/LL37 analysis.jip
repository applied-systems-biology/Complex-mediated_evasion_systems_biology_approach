      "8419be7c-2e7c-4d9c-9cba-062c06a80dd4/add-name" : {
        "name" : "Add ROI name as column",
        "description" : "If enabled, a column 'Name' containing the ROI name is created. You can modify this name via the 'Change ROI properties' node."
      },
      "f89b9255-ca7b-4be2-a136-39d84a034e4e/channel-name-annotation" : {
