        "description" : "Algorithms with multiple inputs require to match the incoming data to data sets. This allows you to determine how interesting data annotation columns are extracted from the incoming data. Union matches using the union of annotation columns. Intersection intersects the sets of available columns. You can also customize which columns should be included or excluded."
      },
      "ae043d63-0f21-4306-8bbe-4d80f47b91da/jipipe:parameter-slot-algorithm/parameter-annotations-prefix" : {
        "name" : "Parameter annotation prefix",
        "description" : "Text prefixed to generated parameter annotations."
      },
      "7fb309bc-9a02-4a7d-9ab4-dfa98dca3a7a/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "8419be7c-2e7c-4d9c-9cba-062c06a80dd4/measure-in-physical-units" : {
        "name" : "Measure in physical units",
        "description" : "If true, measurements will be generated in physical units if available"
      },
      "1d4a159b-f7cb-4012-b88f-c99e1a816faa/auto-relativize-paths" : {
        "name" : "Automatically make paths relative",
        "description" : "If enabled, absolute paths are made relative to the project file when the project is saved."
      },
      "05e784ad-ccb1-4f21-963f-9c19252344e3/tweaks-settings/generate-connected-components" : {
        "name" : "Generate connected components",
        "description" : "If enabled, JIPipe will apply a connected component labeling to the annotated masks. If disabled, Cellpose is provided with the labels as-is, which might result in issues with the training."
      },
      "a558b5f8-8552-45ad-b7ec-a08074ac54ea/jipipe:adaptive-parameters/attach-only-non-default-parameter-annotations" : {
