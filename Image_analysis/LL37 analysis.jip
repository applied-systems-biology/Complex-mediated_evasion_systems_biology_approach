      "5c6bcf87-554d-4def-80d1-a4dc4cafc579/jipipe:data-batch-generation/limit" : {
        "name" : "Limit",
        "description" : "Limits which iteration steps are generated. The first index is zero."
      },
      "cf286d4a-3307-4a40-a40d-cd52de05fad8/indices-c" : {
        "name" : "Indices (Channel)",
        "description" : "Array of channel/C indices to be included in the final image.. All indices begin with zero. Indices outside the available range are automatically wrapped. Return an empty array to skip a slice.\n\nThe format is the following: [range];[range];... with [range] either being a single integer or a range [from]-[to] (both inclusive). Negative values must be enclosed in parentheses. Example: 0-5;1;(-1)-10. If you want more customization options use the expression mode and functions such as MAKE_SEQUENCE."
      },
      "63e14dd7-fdba-43cd-ae7d-51bbcedb6ebb/jipipe:algorithm:runtime-partition" : {
        "pinned" : true,
        "name" : "Partition",
        "description" : "Allows to move the node into a different runtime partition, which determine how the workload is executed."
      },
      "c6fbe889-8e4a-4126-8e5e-e72056960a16/jipipe:node:name" : {
        "pinned" : true,
        "name" : "Name",
        "description" : "Custom algorithm name."
      },
      "b52233c1-d02c-460f-96b0-52878d614359/jipipe:parameter-slot-algorithm/parameter-annotations-use-internal-names" : {
        "name" : "Parameter annotations use internal names",
        "description" : "Generated parameter annotations use their internal unique names."
      },
      "4d2d4139-d605-4ec7-8315-2fa8be4ebe2a/image-plane-number-annotation" : {
        "name" : "Annotate with number of planes",
        "description" : "If enabled, an annotation with provided name is created. The annotation contains the number of 2D image planes (also referred as 'Stack size'). Please note that this value might be different from the number of Z slices. This number is size(Z) * size(C) * size(T)."
      },
      "05e784ad-ccb1-4f21-963f-9c19252344e3/jipipe:data-batch-generation/data-annotation-merge-strategy" : {
        "name" : "Merge same data annotation values",
        "description" : "Determines which strategy is applied if different values for the same data annotation columns are encountered."
      },
      "7732d32a-cc29-44ab-bfd2-92269e18d274/jipipe:algorithm:pass-through" : {
        "pinned" : true,
        "name" : "Pass through",
        "description" : "If enabled, the algorithm will pass the input data directly to the output data without any processing. This is different from enabling/disabling the algorithm as this will not disable dependent algorithms.\nPlease note that setting this parameter via adaptive parameters (if available) does not always yield the expected result. The reason behind this is that pass-through is not trivial for certain nodes. We recommend to use a split node if node execution should be made adaptive."
      },
      "d7905d30-f5cf-4a31-9fa3-68d98ffa2110/split-focal-planes" : {
