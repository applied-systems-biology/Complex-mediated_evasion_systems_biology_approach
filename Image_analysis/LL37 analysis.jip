        "description" : "If enabled, there will be an additional slot that consumes parameter data sets. The algorithm then will be applied for each of this parameter sets."
      },
      "66afdeb7-e686-445c-be24-89d31e22005d/color-space-annotation" : {
        "name" : "Annotate with color space",
        "description" : "If enabled, the color space is stored in an annotation. If a greyscale image is provided, the color space will be 'Greyscale'."
      },
      "9bc9dd80-a07c-45a9-b8d8-9d4d1f0fe05c/split-channels" : {
        "name" : "Split channels",
        "description" : "Each channel is opened as a separate stack.  This option is especially useful if you want to merge the channels into a specific order, rather than automatically assign channels to the order of RGB. The bit depth is preserved."
      },
      "edba19f4-66f8-4359-b7a7-74b69445d2ff/jipipe:data-batch-generation/annotation-matching-method" : {
