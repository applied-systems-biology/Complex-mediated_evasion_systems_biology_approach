      "54179c5e-ca57-444c-881b-c50ebe0ab98a/auto-scale" : {
        "name" : "Auto scale",
        "description" : "Stretches the channel histograms to each channel's global minimum and maximum value throughout the stack. Does not alter underlying values in the image.  If unselected, all channel histograms are scaled to the image's digitization bit depth. Note that this range may be narrower than the bit depth of the file. For example, a 16-bit file may contain intensities digitized to 16-bits (0-65,535), to 12-bits (0-4,095), to 10-bits (0-1,023), etc.  Note that you can use the Brightness & Contrast or Window/Level controls to adjust the contrast range regardless of whether this option is used. The histogram will provide min/max values in the stack."
      },
      "2a59a57d-dd64-4892-8b0b-06e20148e2a6/jipipe:adaptive-parameters/parameter-annotations-use-internal-names" : {
