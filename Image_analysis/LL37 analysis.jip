      "0cf44d83-ddaf-4737-a666-d95c634be270/jipipe:data-batch-generation/annotation-matching-method" : {
        "name" : "Annotation matching method",
        "description" : "Allows to customize when two annotation sets are considered as equal. By default, non-empty annotation values should match exactly. You can also use a custom expression, instead."
      },
      "a2479b31-f8a5-427d-9fc7-9440175e933f/jipipe:data-batch-generation/column-matching" : {
        "important" : true,
        "pinned" : true,
        "name" : "Grouping method",
        "description" : "Algorithms with multiple inputs require to match the incoming data to data sets. This allows you to determine how interesting data annotation columns are extracted from the incoming data. Union matches using the union of annotation columns. Intersection intersects the sets of available columns. You can also customize which columns should be included or excluded."
      },
      "04dbb91c-836f-4f44-a33e-b7b0933be3d2/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "0a4f76e8-b5f2-4eb8-a556-75c787f4fdb8/jipipe:data-batch-generation/skip-incomplete" : {
